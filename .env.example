# Zotero Sync Configuration

# Path to your Zotero storage directory
# Default: ~/Zotero/storage (or equivalent on Windows)
# Example: ZOTERO_STORAGE_PATH=/Users/yourname/Zotero/storage
ZOTERO_STORAGE_PATH=

# Path to your GitHub repository
# Default: Current working directory
# Example: GITHUB_REPO_PATH=/Users/yourname/projects/zotero-research
GITHUB_REPO_PATH=

# Custom commit message
# Default: "Sync Zotero files"
# Example: COMMIT_MESSAGE="Update research files from Zotero"
COMMIT_MESSAGE=